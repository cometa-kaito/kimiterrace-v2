{
  "name": "@kimiterrace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "PostgreSQL + pgvector スキーマ（Drizzle）。テナント分離は RLS で強制 (CLAUDE.md ルール2)。",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./dist/schema/index.js"
    },
    "./tv-schedule": {
      "types": "./src/schema/tv-schedule.ts",
      "default": "./dist/schema/tv-schedule.js"
    },
    "./migrate-files": {
      "types": "./src/migrate-files.ts",
      "default": "./dist/migrate-files.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src __tests__",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "migrate:apply": "node dist/migrate-cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@kimiterrace/ai": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
