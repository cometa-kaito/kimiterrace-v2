{
  "name": "@kimiterrace/ai",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "F03 AI 構造化。Vertex AI Gemini で自由入力を構造化 JSON 化。PII マスキング + confidence_score + 監査 (CLAUDE.md ルール4)。",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./embedding-dim": {
      "types": "./src/model/embedding-dim.ts",
      "default": "./dist/model/embedding-dim.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "^5.0.16",
    "@google-cloud/vision": "^5.3.6",
    "ai": "^5.0.52",
    "exceljs": "^4.4.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
