# キミテラス v2 — 環境変数サンプル
#
# このファイルは公開（コミット）されます。実値は .env に書き、.env はコミットしない。
# シークレットは Secret Manager から取得すること（CLAUDE.md ルール5）。

# --- ローカル開発用 PostgreSQL ---
# infrastructure/docker/docker-compose.dev.yml で起動する DB に接続する想定。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kimiterrace_dev"

# --- アプリ設定 ---
NODE_ENV="development"

# --- GCP（ローカルでは未設定で OK。本番は Workload Identity 経由） ---
# GOOGLE_CLOUD_PROJECT="signage-v2-prod"
# GOOGLE_CLOUD_REGION="asia-northeast1"
