# apps/web — 環境変数サンプル
#
# このファイルは公開（コミット）されます。実値は .env.local に書き、.env.local はコミットしない。
# シークレットは Secret Manager から取得すること（CLAUDE.md ルール5）。

# --- DB 接続 ---
# 実 import は別 Issue で実装。現状は placeholder。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kimiterrace_dev"

# --- アプリ URL ---
# Cloud Run では発行された URL を Workload Identity 経由で渡す。
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Identity Platform (認証, ADR-003) ---
# Admin SDK (server) は Application Default Credentials (Workload Identity) で初期化する。
# JSON キーファイルは配布しない（CLAUDE.md ルール5）。projectId は公開値:
GOOGLE_CLOUD_PROJECT="kimiterrace-dev"
#
# client SDK (firebase) の config は公開値（秘密ではない）。ブラウザに配布されるため
# NEXT_PUBLIC_ で渡す。真の認可は session cookie 検証 + RLS で担保する。
NEXT_PUBLIC_FIREBASE_API_KEY="public-web-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="kimiterrace-dev.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="kimiterrace-dev"

# --- TV デバイスポーリング (F15/F16, ADR-022) ---
# Google TV の `GET /api/tv/config?key=...` 共有シークレット。本番は Secret Manager（CLAUDE.md ルール5）。
# 未設定だとポーリングを全拒否（fail-closed）。Phase 2 で TV 個別トークン（tv_device_tokens）に移行。
TV_POLL_SECRET="dev-tv-poll-secret"

# --- Partner API 共有シークレット (portal ↔ v2, partner-api-contract §1) ---
# portal の Vercel サーバーが `x-partner-key` / `Authorization: Bearer` で v2 を叩く際の共有シークレット。
# 本番は Secret Manager（CLAUDE.md ルール5）。未設定だと Partner API を全拒否（fail-closed・401）。
# portal 側は同値を Vercel env / integration_secrets に保持する。
PARTNER_API_SECRET="dev-partner-api-secret"

# --- MFA 強制エンフォース (F11, ADR-031) ---
# teacher 以上に MFA を強制するか。**既定 OFF**（PoC は任意、未登録でもログイン可）。
# 厳密に "on" のときだけ有効化され、未登録の teacher 以上を /app/account/mfa へ誘導する。
# 本番導入ゲートで "on" + Terraform mfa_state=ENABLED を対で有効化する。秘密ではない（feature flag）。
# MFA_ENFORCEMENT="off"

# --- ビルドメタ ---
# CI で git short SHA を埋め込む。ローカルは未設定で OK（health は "dev" を返す）。
# GIT_COMMIT=""
