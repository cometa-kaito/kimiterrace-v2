# apps/web — 環境変数サンプル
#
# このファイルは公開（コミット）されます。実値は .env.local に書き、.env.local はコミットしない。
# シークレットは Secret Manager から取得すること（CLAUDE.md ルール5）。

# --- DB 接続 ---
# 実 import は別 Issue で実装。現状は placeholder。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kimiterrace_dev"

# --- アプリ URL ---
# Cloud Run では発行された URL を Workload Identity 経由で渡す。
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Identity Platform (認証, ADR-003) ---
# Admin SDK (server) は Application Default Credentials (Workload Identity) で初期化する。
# JSON キーファイルは配布しない（CLAUDE.md ルール5）。projectId は公開値:
GOOGLE_CLOUD_PROJECT="kimiterrace-dev"
#
# client SDK (firebase) の config は公開値（秘密ではない）。ブラウザに配布されるため
# NEXT_PUBLIC_ で渡す。真の認可は session cookie 検証 + RLS で担保する。
NEXT_PUBLIC_FIREBASE_API_KEY="public-web-api-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="kimiterrace-dev.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="kimiterrace-dev"

# --- ビルドメタ ---
# CI で git short SHA を埋め込む。ローカルは未設定で OK（health は "dev" を返す）。
# GIT_COMMIT=""
